<% content_for(:title) { "Edit #{@developer.name} — Capacity Planning" } %>

<div class="planning-layout">
  <header class="planning-header">
    <div>
      <p class="planning-header__eyebrow">People</p>
      <h1>Edit Developer</h1>
      <p>Update details for <%= @developer.name %>.</p>
    </div>
    <%= link_to "Back to Profile", planning_developer_path(@developer), class: "planning-btn" %>
  </header>

  <section class="planning-form-card">
    <%= render "planning/developers/form",
              developer: @developer,
              teams: @teams,
              url: planning_developer_path(@developer),
              method: :patch,
              submit_label: "Update Developer" %>
  </section>
</div>

<% content_for(:title) { "New Developer — Capacity Planning" } %>

<div class="planning-layout">
  <header class="planning-header">
    <div>
      <p class="planning-header__eyebrow">People</p>
      <h1>New Developer</h1>
      <p>Register a new developer for capacity planning.</p>
    </div>
    <%= link_to "Back to Developers", planning_developers_path, class: "planning-btn" %>
  </header>

  <section class="planning-form-card">
    <%= render "planning/developers/form",
              developer: @developer,
              teams: @teams,
              url: planning_developers_path,
              method: :post,
              submit_label: "Create Developer" %>
  </section>
</div>

<% content_for(:title) { "Edit #{@deliverable.title} — Capacity Planning" } %>

<div class="planning-layout">
  <header class="planning-header">
    <div>
      <p class="planning-header__eyebrow">Backlog &amp; Tasks</p>
      <h1>Edit Deliverable</h1>
      <p>Update details for <%= @deliverable.title %>.</p>
    </div>
    <%= link_to "Back to Deliverables", planning_deliverables_path, class: "planning-btn" %>
  </header>

  <section class="planning-form-card">
    <%= render "planning/deliverables/form",
              deliverable: @deliverable,
              teams: @teams,
              cycles: @cycles,
              url: planning_deliverable_path(@deliverable),
              method: :patch,
              submit_label: "Update Deliverable" %>
  </section>
</div>

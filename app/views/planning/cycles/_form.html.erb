<%= form_with(model: cycle, url: url, method: method, class: "planning-form") do |f| %>
  <% if cycle.errors.any? %>
    <div class="planning-form__errors">
      <p><strong><%= pluralize(cycle.errors.count, "error") %> prevented this cycle from being saved:</strong></p>
      <ul>
        <% cycle.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="planning-form__field">
    <%= f.label :name, "Cycle Name" %>
    <%= f.text_field :name, placeholder: "e.g. Sprint 42", autofocus: true %>
  </div>

  <div class="planning-form__row">
    <div class="planning-form__field">
      <%= f.label :start_date, "Start Date" %>
      <%= f.date_field :start_date %>
    </div>

    <div class="planning-form__field">
      <%= f.label :end_date, "End Date" %>
      <%= f.date_field :end_date %>
    </div>
  </div>

  <div class="planning-form__actions">
    <%= f.submit submit_label, class: "planning-btn planning-btn--primary" %>
  </div>
<% end %>

<% content_for(:title) { "Support Tickets" } %>

<%= render 'metrics/jira_bugs/topbar' %>

<style>
  .support-tickets {
    max-width: 1400px;
    margin: 2rem auto;
    padding: 0 1.5rem;
    font-family: var(--font-sans);
    color: var(--text-primary);
  }
  .support-tickets__header { margin-bottom: 1.5rem; }
  .support-tickets__header h1 { font-size: 1.5rem; font-weight: 600; margin: 0 0 0.25rem; }
  .support-tickets__header p { color: var(--text-secondary); margin: 0; font-size: 0.95rem; }
  .support-tickets__filters {
    display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;
    margin-bottom: 1.5rem; padding: 1rem;
    background: var(--bg-overlay); border: 1px solid var(--border); border-radius: 0.5rem;
  }
  .support-tickets__field { display: flex; flex-direction: column; gap: 0.25rem; }
  .support-tickets__field label { font-size: 0.8rem; font-weight: 500; color: var(--text-secondary); }
  .support-tickets__btn {
    padding: 0.45rem 1rem; background: var(--accent-blue); color: #fff; border: none;
    border-radius: 0.375rem; font-size: 0.875rem; cursor: pointer; font-weight: 500;
  }
  .support-tickets__btn:hover { background: #79c0ff; }
  .support-tickets__table-wrap {
    overflow-x: auto; border: 1px solid var(--border); border-radius: 0.5rem;
  }
  .support-tickets__table {
    width: 100%; border-collapse: collapse; font-size: 0.875rem;
  }
  .support-tickets__table th {
    text-align: left; padding: 0.6rem 0.75rem; background: var(--bg-muted);
    font-weight: 600; color: var(--text-secondary); border-bottom: 2px solid var(--border);
    white-space: nowrap;
  }
  .support-tickets__table td {
    padding: 0.55rem 0.75rem; border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .support-tickets__table tr:hover td { background: var(--bg-overlay); }
  .support-tickets__table a {
    color: var(--accent-blue); text-decoration: none; font-weight: 500;
  }
  .support-tickets__table a:hover { text-decoration: underline; }
  .support-tickets__tag {
    display: inline-block; padding: 0.15rem 0.45rem; margin: 0.1rem 0.15rem;
    font-size: 0.72rem; border-radius: 0.25rem; font-weight: 500;
  }
  .support-tickets__tag--status { background: rgba(88, 166, 255, 0.1); color: var(--accent-blue); }
  .support-tickets__tag--priority { background: rgba(210, 153, 34, 0.1); color: var(--accent-orange); }
  .support-tickets__tag--component { background: rgba(188, 140, 255, 0.12); color: var(--accent-purple); }
  .support-tickets__empty {
    display: flex; align-items: center; justify-content: center;
    height: 200px; color: var(--text-muted); font-size: 0.95rem;
  }
  .support-tickets__date { white-space: nowrap; color: var(--text-secondary); font-size: 0.8rem; }
  .support-tickets__back {
    display: inline-flex; align-items: center; gap: 0.3rem;
    color: var(--text-secondary); text-decoration: none; font-size: 0.85rem;
    margin-bottom: 1rem; font-weight: 500;
  }
  .support-tickets__back:hover { color: var(--accent-blue); }
  .support-tickets__actions {
    display: flex; align-items: center; gap: 1rem;
    margin-bottom: 1rem;
  }
  .support-tickets__btn--clone {
    padding: 0.45rem 1rem; background: var(--accent-orange, #d2991f); color: #fff; border: none;
    border-radius: 0.375rem; font-size: 0.875rem; cursor: pointer; font-weight: 500;
  }
  .support-tickets__btn--clone:hover { background: #e5a825; }
  .support-tickets__btn--clone:disabled { opacity: 0.5; cursor: not-allowed; }
  .support-tickets__select-count { font-size: 0.85rem; color: var(--text-secondary); }
  .support-tickets__flash {
    padding: 0.6rem 1rem; margin-bottom: 1rem; border-radius: 0.375rem;
    font-size: 0.875rem; background: rgba(88, 166, 255, 0.1); color: var(--accent-blue);
    border: 1px solid rgba(88, 166, 255, 0.3);
  }
</style>

<div class="support-tickets">
  <a href="<%= metrics_dashboard_path %>" class="support-tickets__back">&#8592; Dashboard</a>

  <header class="support-tickets__header">
    <h1>Support Tickets</h1>
    <p>Listing support tickets by team, ordered by most recent. Total: <strong><%= @total %></strong> tickets.</p>
  </header>

  <div class="support-tickets__filters">
    <%= form_tag(metrics_support_tickets_path, method: :get, style: "display:contents;") do %>
      <div class="support-tickets__field">
        <label for="start_date">From</label>
        <input type="date" name="start_date" id="start_date" value="<%= @start_date %>">
      </div>
      <div class="support-tickets__field">
        <label for="end_date">To</label>
        <input type="date" name="end_date" id="end_date" value="<%= @end_date %>">
      </div>
      <div class="support-tickets__field">
        <label for="team">Team</label>
        <input type="text" name="team" id="team" value="<%= @team %>" placeholder="e.g. Digital Farm">
      </div>
      <div class="support-tickets__field">
        <label for="status">Status</label>
        <select name="status" id="status">
          <option value="">All</option>
          <% @statuses.each do |s| %>
            <option value="<%= s %>" <%= "selected" if @status == s %>><%= s %></option>
          <% end %>
        </select>
      </div>
      <div class="support-tickets__field">
        <label for="priority">Priority</label>
        <select name="priority" id="priority">
          <option value="">All</option>
          <% @priorities.each do |p| %>
            <option value="<%= p %>" <%= "selected" if @priority == p %>><%= p %></option>
          <% end %>
        </select>
      </div>
      <button type="submit" class="support-tickets__btn">Apply</button>
    <% end %>
  </div>

  <% if @tickets.any? %>
    <% if flash[:notice] %>
      <div class="support-tickets__flash"><%= flash[:notice] %></div>
    <% end %>

    <%= form_tag(metrics_support_tickets_clone_to_bugs_path, method: :post) do %>
      <div class="support-tickets__actions" style="display: flex; justify-content: flex-end; align-items: center; gap: 1rem;">
        <span class="support-tickets__select-count" id="select-count">0 selected</span>
        <button type="submit" class="support-tickets__btn--clone" id="clone-btn" disabled>
          Clone selected to Bugs
        </button>
      </div>

      <div class="support-tickets__table-wrap">
        <table class="support-tickets__table">
          <thead>
            <tr>
              <th><input type="checkbox" id="select-all"></th>
              <th>Issue Key</th>
              <th>Title</th>
              <th>Status</th>
              <th>Priority</th>
              <th>Assignee</th>
              <th>Reporter</th>
              <th>Components</th>
              <th>Opened At</th>
              <th>Cloned</th>
            </tr>
          </thead>
          <tbody>
            <% @tickets.each do |ticket| %>
              <tr>
              <td>
                <% if ticket[:cloned_to_bug_key].present? %>
                  <span title="Already cloned to <%= ticket[:cloned_to_bug_key] %>">&#10003;</span>
                <% else %>
                  <input type="checkbox" name="ticket_ids[]" value="<%= ticket[:id] %>" class="ticket-checkbox">
                <% end %>
              </td>
                <td>
                  <a href="<%= ticket[:jira_link] %>" target="_blank" rel="noopener">
                    <%= ticket[:issue_key] %>
                  </a>
                </td>
                <td><%= ticket[:title] %></td>
                <td>
                  <span class="support-tickets__tag support-tickets__tag--status"><%= ticket[:status] %></span>
                </td>
                <td>
                  <% if ticket[:priority].present? %>
                    <span class="support-tickets__tag support-tickets__tag--priority"><%= ticket[:priority] %></span>
                  <% end %>
                </td>
                <td><%= ticket[:assignee] %></td>
                <td><%= ticket[:reporter] %></td>
                <td>
                  <% Array(ticket[:components]).each do |comp| %>
                    <span class="support-tickets__tag support-tickets__tag--component"><%= comp %></span>
                  <% end %>
                </td>
                <td>
                  <span class="support-tickets__date"><%= ticket[:opened_at]&.in_time_zone("America/Sao_Paulo")&.strftime("%d/%m/%Y") %></span>
                </td>
                <td>
                  <% if ticket[:cloned_to_bug_key].present? %>
                    <a href="<%= @jira_base_url %>/browse/<%= ticket[:cloned_to_bug_key] %>" target="_blank" rel="noopener" class="support-tickets__tag support-tickets__tag--status">
                      <%= ticket[:cloned_to_bug_key] %>
                    </a>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <script>
      document.addEventListener("turbo:load", function() {
        const selectAll = document.getElementById("select-all");
        const cloneBtn = document.getElementById("clone-btn");
        const countEl = document.getElementById("select-count");
        const checkboxes = () => document.querySelectorAll(".ticket-checkbox");

        function updateState() {
          const checked = document.querySelectorAll(".ticket-checkbox:checked").length;
          cloneBtn.disabled = checked === 0;
          countEl.textContent = checked + " selected";
          const all = checkboxes();
          selectAll.checked = all.length > 0 && checked === all.length;
          selectAll.indeterminate = checked > 0 && checked < all.length;
        }

        selectAll.addEventListener("change", function() {
          checkboxes().forEach(cb => cb.checked = selectAll.checked);
          updateState();
        });

        document.querySelector(".support-tickets__table").addEventListener("change", function(e) {
          if (e.target.classList.contains("ticket-checkbox")) updateState();
        });
      });
    </script>
  <% else %>
    <div class="support-tickets__empty">No support tickets found for the selected filters.</div>
  <% end %>
</div>

<style>
  .jira-topbar {
    background: rgba(13, 17, 23, 0.92);
    padding: 0.5rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-sans);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
  }
  .jira-topbar__sep {
    width: 1px;
    height: 20px;
    background: var(--border);
    flex-shrink: 0;
  }
  .jira-topbar__nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
    overflow-x: auto;
  }
  .jira-topbar__link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.4rem 0.75rem;
    border-radius: 1.25rem;
    white-space: nowrap;
    transition: color 0.15s, background 0.15s;
  }
  .jira-topbar__link:hover {
    color: var(--text-primary);
    background: var(--bg-muted);
  }
  .jira-topbar__link--active {
    color: var(--accent-blue);
    background: rgba(88, 166, 255, 0.1);
  }
  .jira-topbar__link--active:hover {
    background: rgba(88, 166, 255, 0.15);
  }
</style>

<%
  shared_params = { start_date: @start_date, end_date: @end_date, team: @team }.compact_blank
%>

<nav class="jira-topbar">
  <%= render "shared/section_switcher", current_section: :metrics %>
  <span class="jira-topbar__sep"></span>
  <div class="jira-topbar__nav">
    <a href="<%= metrics_dashboard_path %>"
       class="jira-topbar__link<%= ' jira-topbar__link--active' if current_page?(metrics_dashboard_path) %>">
      Dashboard
    </a>
    <a href="<%= metrics_jira_bugs_bubble_chart_page_path(shared_params) %>"
       class="jira-topbar__link<%= ' jira-topbar__link--active' if current_page?(metrics_jira_bugs_bubble_chart_page_path) %>">
      Category Chart
    </a>
    <a href="<%= metrics_jira_bugs_all_path(shared_params) %>"
       class="jira-topbar__link<%= ' jira-topbar__link--active' if current_page?(metrics_jira_bugs_all_path) %>">
      All Bugs
    </a>
    <a href="<%= metrics_jira_bugs_over_time_path(shared_params) %>"
       class="jira-topbar__link<%= ' jira-topbar__link--active' if current_page?(metrics_jira_bugs_over_time_path) %>">
      Bugs Over Time
    </a>
    <a href="<%= metrics_jira_bugs_invalid_categories_page_path(shared_params) %>"
       class="jira-topbar__link<%= ' jira-topbar__link--active' if current_page?(metrics_jira_bugs_invalid_categories_page_path) %>">
      Invalid Categories
    </a>
    <a href="<%= metrics_support_tickets_path(shared_params) %>"
       class="jira-topbar__link<%= ' jira-topbar__link--active' if controller_name == 'support_tickets' %>">
      Support Tickets
    </a>
  </div>
</nav>

<% content_for(:title) { "Invalid Categories" } %>

<style>
  .inv-page {
    max-width: 1200px;
    margin: 2rem auto;
    padding: 0 1.5rem;
    font-family: var(--font-sans);
    color: var(--text-primary);
  }
  .inv-page__header { margin-bottom: 1.5rem; }
  .inv-page__header h1 { font-size: 1.5rem; font-weight: 600; margin: 0 0 0.25rem; }
  .inv-page__header p { color: var(--text-secondary); margin: 0; font-size: 0.95rem; }
  .inv-page__filters {
    display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;
    margin-bottom: 1.5rem; padding: 1rem;
    background: var(--bg-overlay); border: 1px solid var(--border); border-radius: 0.5rem;
  }
  .inv-page__field { display: flex; flex-direction: column; gap: 0.25rem; }
  .inv-page__field label { font-size: 0.8rem; font-weight: 500; color: var(--text-secondary); }
  .inv-page__btn {
    padding: 0.45rem 1rem; background: var(--accent-blue); color: #fff; border: none;
    border-radius: 0.375rem; font-size: 0.875rem; cursor: pointer; font-weight: 500;
  }
  .inv-page__btn:hover { background: #79c0ff; }
  .inv-page__table-wrap {
    overflow-x: auto; border: 1px solid var(--border); border-radius: 0.5rem;
  }
  .inv-page__table {
    width: 100%; border-collapse: collapse; font-size: 0.875rem;
  }
  .inv-page__table th {
    text-align: left; padding: 0.6rem 0.75rem; background: var(--bg-muted);
    font-weight: 600; color: var(--text-secondary); border-bottom: 2px solid var(--border);
    white-space: nowrap;
  }
  .inv-page__table td {
    padding: 0.55rem 0.75rem; border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .inv-page__table tr:hover td { background: var(--bg-overlay); }
  .inv-page__table a {
    color: var(--accent-blue); text-decoration: none; font-weight: 500;
  }
  .inv-page__table a:hover { text-decoration: underline; }
  .inv-page__reason {
    display: inline-block; padding: 0.15rem 0.45rem; margin: 0.1rem 0.15rem;
    font-size: 0.75rem; border-radius: 0.25rem; font-weight: 500;
  }
  .inv-page__reason--missing_project_category {
    background: rgba(210, 153, 34, 0.12); color: var(--accent-orange);
  }
  .inv-page__reason--missing_feature_category {
    background: rgba(248, 81, 73, 0.1); color: var(--accent-red);
  }
  .inv-page__reason--missing_mfe_category {
    background: rgba(188, 140, 255, 0.12); color: var(--accent-purple);
  }
  .inv-page__empty {
    display: flex; align-items: center; justify-content: center;
    height: 200px; color: var(--text-muted); font-size: 0.95rem;
  }
  .inv-page__flash {
    padding: 0.6rem 1rem; border-radius: 0.375rem; margin-bottom: 1rem;
    font-size: 0.875rem; font-weight: 500;
  }
  .inv-page__flash--notice { background: rgba(63, 185, 80, 0.1); color: var(--accent-green); border: 1px solid rgba(63, 185, 80, 0.3); }
  .inv-page__flash--alert { background: rgba(248, 81, 73, 0.1); color: var(--accent-red); border: 1px solid rgba(248, 81, 73, 0.3); }
  .inv-page__sync-btn {
    padding: 0.45rem 1rem; background: var(--accent-green); color: #fff; border: none;
    border-radius: 0.375rem; font-size: 0.875rem; cursor: pointer; font-weight: 500;
    margin-left: auto;
  }
  .inv-page__sync-btn:hover { background: #56d364; }
</style>

<%= render 'metrics/jira_bugs/topbar' %>

<div class="inv-page">
  <% if flash[:notice] %>
    <div class="inv-page__flash inv-page__flash--notice"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="inv-page__flash inv-page__flash--alert"><%= flash[:alert] %></div>
  <% end %>

  <header class="inv-page__header">
    <h1>Bugs with Invalid Categories</h1>
    <p>Listing "Done" bugs that are missing required category labels. Total: <strong><%= @invalid_bugs.size %></strong> bugs.</p>
  </header>

  <div class="inv-page__filters">
    <%= form_tag(metrics_jira_bugs_invalid_categories_page_path, method: :get, style: "display:contents;") do %>
      <div class="inv-page__field">
        <label for="start_date">From</label>
        <input type="date" name="start_date" id="start_date" value="<%= @start_date %>">
      </div>
      <div class="inv-page__field">
        <label for="end_date">To</label>
        <input type="date" name="end_date" id="end_date" value="<%= @end_date %>">
      </div>
      <div class="inv-page__field">
        <label for="team">Team</label>
        <input type="text" name="team" id="team" value="<%= @team %>" placeholder="e.g. Digital Farm">
      </div>
      <button type="submit" class="inv-page__btn">Apply</button>
    <% end %>
    <%= button_to "Sync from JIRA",
        metrics_jira_bugs_sync_from_jira_path(team: @team, start_date: @start_date, end_date: @end_date),
        method: :post, class: "inv-page__sync-btn", form: { style: "margin-left: auto;" },
        data: { confirm: "This will fetch all bugs from JIRA. It may take a while. Continue?",
                turbo_confirm: "This will fetch all bugs from JIRA. It may take a while. Continue?" } %>
  </div>

  <% if @invalid_bugs.any? %>
    <div class="inv-page__table-wrap">
      <table class="inv-page__table">
        <thead>
          <tr>
            <th>Issue Key</th>
            <th>Title</th>
            <th>Opened At</th>
            <th>Reasons</th>
          </tr>
        </thead>
        <tbody>
          <% @invalid_bugs.each do |bug| %>
            <tr>
              <td><a href="<%= bug[:jira_link] %>" target="_blank" rel="noopener"><%= bug[:issue_key] %></a></td>
              <td><%= bug[:title] %></td>
              <td style="white-space:nowrap;"><%= bug[:opened_at]&.in_time_zone('America/Sao_Paulo')&.strftime('%d/%m/%Y %H:%M') %></td>
              <td>
                <% bug[:reasons].each do |reason| %>
                  <span class="inv-page__reason inv-page__reason--<%= reason %>"><%= reason.humanize %></span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="inv-page__empty">No bugs with invalid categories found.</div>
  <% end %>
</div>

<% content_for(:title) { "Bug Category Analysis" } %>
<% content_for(:head) do %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.js"></script>
<% end %>

<style>
  .chart-page {
    max-width: 1200px;
    margin: 2rem auto;
    padding: 0 1.5rem;
    font-family: var(--font-sans);
    color: var(--text-primary);
  }
  .chart-page__header { margin-bottom: 1.5rem; }
  .chart-page__header h1 { font-size: 1.5rem; font-weight: 600; margin: 0 0 0.25rem; }
  .chart-page__header p { color: var(--text-secondary); margin: 0; font-size: 0.95rem; }
  .chart-page__filters {
    display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;
    margin-bottom: 1.5rem; padding: 1rem;
    background: var(--bg-overlay); border: 1px solid var(--border); border-radius: 0.5rem;
  }
  .chart-page__field { display: flex; flex-direction: column; gap: 0.25rem; }
  .chart-page__field label { font-size: 0.8rem; font-weight: 500; color: var(--text-secondary); }
  .chart-page__btn {
    padding: 0.45rem 1rem; background: var(--accent-blue); color: #fff; border: none;
    border-radius: 0.375rem; font-size: 0.875rem; cursor: pointer; font-weight: 500;
  }
  .chart-page__btn:hover { background: #79c0ff; }
  .chart-page__chart-wrapper {
    position: relative; width: 100%; background: var(--bg-surface);
    border: 1px solid var(--border); border-radius: 0.5rem; padding: 1rem;
    height: <%= [480, @chart_labels.size * 28 + 80].max %>px;
  }
  .chart-page__empty {
    display: flex; align-items: center; justify-content: center;
    height: 200px; color: var(--text-muted); font-size: 0.95rem;
  }
  .chart-page__multi-select {
    min-width: 220px; max-width: 320px; height: auto; max-height: 160px;
    font-size: 0.85rem; border: 1px solid var(--border); border-radius: 0.375rem;
    padding: 0.25rem;
  }
  .chart-page__multi-select option { padding: 0.2rem 0.4rem; }
  .chart-page__hint { font-size: 0.7rem; color: var(--text-muted); margin-top: 0.15rem; }
</style>

<%= render 'metrics/jira_bugs/topbar' %>

<div class="chart-page">
  <header class="chart-page__header">
    <h1>Bug Category Analysis</h1>
    <p>Bar chart showing the count of "Done" bugs grouped by the selected category. Total: <strong><%= @total_bugs %></strong> bugs.</p>
  </header>

  <%= form_tag(metrics_jira_bugs_bubble_chart_page_path, method: :get, class: "chart-page__filters") do %>
    <div class="chart-page__field">
      <label for="category_types">Prefix Filter</label>
      <select name="category_types[]" id="category_types">
        <% JiraBug::CATEGORY_PREFIXES.each do |prefix| %>
          <option value="<%= prefix %>" <%= "selected" if @category_types.include?(prefix) %>><%= prefix %></option>
        <% end %>
        <option value="development_type" <%= "selected" if @category_types.include?("development_type") %>>development_type</option>
      </select>
    </div>

    <div class="chart-page__field">
      <label for="start_date">From</label>
      <input type="date" name="start_date" id="start_date" value="<%= @start_date %>">
    </div>

    <div class="chart-page__field">
      <label for="end_date">To</label>
      <input type="date" name="end_date" id="end_date" value="<%= @end_date %>">
    </div>

    <div class="chart-page__field">
      <label for="team">Team</label>
      <input type="text" name="team" id="team" value="<%= @team %>"
             placeholder="e.g. Digital Farm">
    </div>

    <div class="chart-page__field">
      <label for="sub_categories">Sub Category</label>
      <select name="sub_category" id="sub_categories">
        <option value="">None</option>
        <% JiraBug::CATEGORY_PREFIXES.each do |prefix| %>
          <option value="<%= prefix %>" <%= "selected" if @sub_category == prefix %>><%= prefix %></option>
        <% end %>
      </select>
    </div>

    <button type="submit" class="chart-page__btn">Apply</button>
  <% end %>

  <% if @chart_labels.any? %>
    <div class="chart-page__chart-wrapper"
         data-controller="bubble-chart"
         data-bubble-chart-labels-value="<%= @chart_labels.to_json %>"
         data-bubble-chart-counts-value="<%= @chart_values.to_json %>"
         data-bubble-chart-title-value="<%= @category_types.join(', ') %>">
      <canvas data-bubble-chart-target="canvas"></canvas>
    </div>
  <% else %>
    <div class="chart-page__empty">No data found for the selected filters.</div>
  <% end %>
</div>


